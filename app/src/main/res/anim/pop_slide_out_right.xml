<?xml version="1.0" encoding="utf-8"?><!-- Premium pop exit animation: slide out to right + fade for exiting when returning to previous screen -->
<set xmlns:android="http://schemas.android.com/apk/res/android">
    <translate
        android:duration="300"
        android:fromXDelta="0%"
        android:interpolator="@interpolator/ease_in_out"
        android:toXDelta="100%" />
    <alpha
        android:duration="250"
        android:fromAlpha="1.0"
        android:toAlpha="0.0" />
</set>


