<?xml version="1.0" encoding="utf-8"?><!-- Premium pop exit animation: fade out for exiting during pop-back from fade-transition screens -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@interpolator/ease_in_out">
    <alpha
        android:duration="250"
        android:fromAlpha="1.0"
        android:toAlpha="0.0" />
</set>


