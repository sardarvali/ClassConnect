<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/ClassConnect.Surface.ListItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_4"
    android:layout_marginVertical="@dimen/space_1"
    android:foreground="?attr/selectableItemBackground"
    app:cardElevation="2dp"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_4">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/icon_container"
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:cardCornerRadius="@dimen/radius_medium"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeWidth="0dp">

            <View
                android:id="@+id/view_color_bar"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_classes"
                app:tint="@color/white" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_class_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_md"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/icon_container"
            app:layout_constraintTop_toTopOf="@+id/icon_container"
            tools:text="Mathematics 101" />

        <TextView
            android:id="@+id/tv_teacher_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:layout_marginTop="@dimen/space_1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_base"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/icon_container"
            app:layout_constraintTop_toBottomOf="@+id/tv_class_name"
            tools:text="Teacher: Mr. Smith" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@+id/icon_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/icon_container"
            app:layout_constraintTop_toBottomOf="@+id/tv_teacher_name">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_unassigned"
                style="@style/ClassConnect.Chip.Compact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/unassigned_teacher_warning"
                android:textColor="@color/semantic_error"
                android:textSize="@dimen/text_xs"
                android:visibility="gone"
                app:chipBackgroundColor="@color/semantic_error_surface"
                app:chipMinTouchTargetSize="0dp"
                app:chipStrokeColor="@color/semantic_error_surface"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_assign_teacher"
                style="@style/ClassConnect.Button.Tonal.Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="@dimen/space_3"
                android:text="@string/assign_teacher"
                android:textColor="@color/brand_primary"
                android:textSize="@dimen/text_xs"
                android:visibility="gone"
                app:backgroundTint="@color/semantic_info_surface"
                app:cornerRadius="@dimen/radius_medium"
                app:strokeColor="@color/brand_primary"
                app:strokeWidth="1dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
