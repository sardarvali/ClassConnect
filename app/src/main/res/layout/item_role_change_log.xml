<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_4"
    android:layout_marginVertical="@dimen/space_1"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardCornerRadius="@dimen/radius_large"
    app:strokeColor="@color/border_subtle"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/space_3">

        <ImageView
            android:id="@+id/iv_role_arrow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="@dimen/space_3"
            android:contentDescription="@string/role_change_history"
            android:src="@drawable/ic_arrow_forward" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_target_user"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_base"
                android:textStyle="bold"
                tools:text="John Doe" />

            <TextView
                android:id="@+id/tv_role_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1"
                android:textColor="@color/brand_primary"
                android:textSize="@dimen/text_sm"
                tools:text="Teacher → Student" />

            <TextView
                android:id="@+id/tv_changed_by"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_xs"
                tools:text="By: Admin Name" />

            <TextView
                android:id="@+id/tv_reason"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_xs"
                android:visibility="gone"
                tools:text="Reason: misconduct" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_2"
            android:textColor="@color/text_hint"
            android:textSize="@dimen/text_xs"
            tools:text="2 hrs ago" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

