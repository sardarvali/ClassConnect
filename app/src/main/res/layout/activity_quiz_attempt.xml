<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_premium">

    <!-- Top bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/top_bar_card"
        style="@style/ClassConnect.Surface.Premium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/radius_large"
        app:strokeColor="@color/premium_glass_stroke"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginHorizontal="@dimen/space_4"
        android:layout_marginTop="@dimen/space_3">

        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_premium_header"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_4"
            android:paddingVertical="@dimen/space_3">

            <TextView
                android:id="@+id/tv_progress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/quiz_progress_placeholder"
                android:textColor="@color/white"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/quiz_timer_placeholder"
                android:textColor="@color/white"
                android:textSize="@dimen/text_base"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_4"
        android:max="10"
        android:progress="1"
        app:indicatorColor="@color/brand_primary"
        app:layout_constraintTop_toBottomOf="@id/top_bar_card"
        app:trackCornerRadius="@dimen/radius_small" />

    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/space_4"
        android:layout_marginTop="@dimen/space_3"
        app:layout_constraintBottom_toTopOf="@id/btn_row"
        app:layout_constraintTop_toBottomOf="@id/progress_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
                android:paddingBottom="@dimen/space_4">

            <com.google.android.material.card.MaterialCardView
                style="@style/ClassConnect.Surface.Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/tv_question"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="2dp"
                    android:padding="@dimen/card_padding"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_base" />
            </com.google.android.material.card.MaterialCardView>

            <RadioGroup
                android:id="@+id/rg_options"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_4"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rb_option0"
                    style="@style/ClassConnect.Radio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_2"
                    android:padding="@dimen/space_3"
                    android:textSize="@dimen/text_base" />

                <RadioButton
                    android:id="@+id/rb_option1"
                    style="@style/ClassConnect.Radio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_2"
                    android:padding="@dimen/space_3"
                    android:textSize="@dimen/text_base" />

                <RadioButton
                    android:id="@+id/rb_option2"
                    style="@style/ClassConnect.Radio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_2"
                    android:padding="@dimen/space_3"
                    android:textSize="@dimen/text_base" />

                <RadioButton
                    android:id="@+id/rb_option3"
                    style="@style/ClassConnect.Radio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/space_3"
                    android:textSize="@dimen/text_base" />
            </RadioGroup>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/btn_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/premium_surface_tint"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/space_4"
        android:paddingVertical="@dimen/space_3"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_prev"
            style="@style/ClassConnect.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/space_2"
            android:layout_weight="1"
            android:text="@string/quiz_previous" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next"
            style="@style/ClassConnect.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/quiz_next" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit"
            style="@style/ClassConnect.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_2"
            android:text="@string/quiz_submit"
            android:visibility="gone" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
