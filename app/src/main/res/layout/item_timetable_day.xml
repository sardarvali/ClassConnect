<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardCornerRadius="14dp"

    app:strokeColor="@color/border_subtle"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- Left: Day name + status dot -->
        <LinearLayout
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDayName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Status: "Scheduled" in green or "No class" in muted -->
            <TextView
                android:id="@+id/tvDayStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_hint"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Center: Time display or "Add time" hint -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/clockIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/text_hint" />

            <TextView
                android:id="@+id/tvTimeDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="Tap to set time"
                android:textColor="@color/text_secondary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Right: Edit button (teacher) or nothing (student) -->
        <ImageView
            android:id="@+id/btnEditDay"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:src="@drawable/ic_edit"
            android:visibility="gone"
            app:tint="@color/text_hint" />

        <!-- Clear button (only when time is set, teacher only) -->
        <ImageView
            android:id="@+id/btnClearDay"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:src="@drawable/ic_close"
            android:visibility="gone"
            app:tint="@color/warning" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
