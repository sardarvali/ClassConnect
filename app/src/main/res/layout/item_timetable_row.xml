<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_3"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="2dp"
    app:strokeColor="@color/border_subtle"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/space_4"
        android:paddingVertical="@dimen/space_4">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/icon_container"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="@dimen/space_4"

            app:cardBackgroundColor="@color/semantic_info_surface"
            app:cardCornerRadius="@dimen/radius_medium">

            <View
                android:id="@+id/icon_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.15" />

            <ImageView
                android:id="@+id/iv_calendar"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_calendar"
                app:tint="@color/brand_primary" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_day"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_base"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/time_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_rounded_16"
            android:backgroundTint="@color/premium_surface_tint"
            android:paddingHorizontal="@dimen/space_3"
            android:paddingVertical="6dp">

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
