<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_surface"
    android:orientation="vertical"
    android:paddingBottom="@dimen/space_6">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/space_3"
        android:layout_marginBottom="@dimen/space_2"
        android:background="@color/border_subtle"
        android:backgroundTint="@color/text_hint" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/screen_padding_h"
        android:paddingTop="@dimen/space_4"
        android:paddingBottom="@dimen/space_3">

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="@dimen/space_2"
            android:contentDescription="@null"
            android:src="@drawable/ic_ai"
            app:tint="@color/brand_primary" />

        <TextView
            android:id="@+id/tv_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/ai_actions_header_generic"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_md"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="@dimen/space_3"
        android:background="@color/border_subtle" />

    <!-- Loading overlay (while action executes) -->
    <LinearLayout
        android:id="@+id/layout_loading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
            android:padding="@dimen/space_4"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="@dimen/space_3" />

        <TextView
            android:id="@+id/tv_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/processing"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm" />
    </LinearLayout>

    <!-- Action cards -->
    <LinearLayout
        android:id="@+id/layout_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/space_4">

        <!-- Share to Chat -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_share_chat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/bg_base"
            app:cardCornerRadius="@dimen/radius_large"
            app:rippleColor="@color/brand_primary"
            app:strokeColor="@color/border_subtle"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/space_4">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="@dimen/space_3"
                    app:cardBackgroundColor="@color/premium_overlay_blue"
                    app:cardCornerRadius="@dimen/radius_medium">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chat"
                        app:tint="@color/premium_tint_blue" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_share_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ai_actions_share_generic"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_share_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:text="@string/ai_actions_share_generic_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm" />
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="@color/text_hint" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Create Assignment and Post -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_make_assignment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/bg_base"
            app:cardCornerRadius="@dimen/radius_large"
            app:rippleColor="@color/brand_primary"
            app:strokeColor="@color/border_subtle"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/space_4">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="@dimen/space_3"
                    app:cardBackgroundColor="@color/premium_overlay_orange"
                    app:cardCornerRadius="@dimen/radius_medium">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_assignment"
                        app:tint="@color/premium_tint_orange" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_assignment_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ai_actions_assignment_generic"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_assignment_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:text="@string/ai_actions_assignment_generic_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm" />
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="@color/text_hint" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Make Quiz -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_make_quiz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/bg_base"
            app:cardCornerRadius="@dimen/radius_large"
            app:rippleColor="@color/brand_primary"
            app:strokeColor="@color/border_subtle"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/space_4">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="@dimen/space_3"
                    app:cardBackgroundColor="@color/premium_overlay_green"
                    app:cardCornerRadius="@dimen/radius_medium">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_quiz"
                        app:tint="@color/premium_tint_green" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_quiz_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ai_actions_quiz_generic"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_quiz_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:text="@string/ai_actions_quiz_generic_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm" />
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="@color/text_hint" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</LinearLayout>

