<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_3"
    android:layout_marginVertical="@dimen/space_1"
    android:background="@drawable/bg_rounded_16"
    android:backgroundTint="@color/bg_surface"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="@dimen/space_3">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_avatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="@dimen/space_3"
        android:contentDescription="@string/user_avatar"
        android:src="@drawable/ic_profile" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_teacher_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_base"
            android:textStyle="bold"
            tools:text="Jane Smith" />

        <TextView
            android:id="@+id/tv_teacher_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm"
            tools:text="jane@school.com" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_class_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_rounded_16"
        android:backgroundTint="@color/semantic_info_surface"
        android:paddingHorizontal="@dimen/space_2"
        android:paddingVertical="@dimen/space_1"
        android:textColor="@color/text_hint"
        android:textSize="@dimen/text_xs"
        tools:text="2 classes" />

</LinearLayout>

