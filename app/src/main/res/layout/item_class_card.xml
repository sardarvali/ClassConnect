                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_people"
                    android:alpha="0.6"/>

                <TextView
                    android:id="@+id/tv_student_count"
                    android:layout_width="wrap_content"
