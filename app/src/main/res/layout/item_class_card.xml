<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/card_margin_h"
    android:layout_marginVertical="@dimen/card_margin_v"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardCornerRadius="@dimen/radius_xlarge"
    app:cardElevation="4dp"
    app:strokeColor="@color/border_subtle"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/card_padding">

        <!-- Gradient Icon Block -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/icon_container"
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:cardCornerRadius="@dimen/radius_large"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeWidth="0dp">

            <!-- Gradient view -->
            <View
                android:id="@+id/view_color_bar"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Icon overlay -->
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_classes"
                app:tint="@color/white" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Details -->
        <TextView
            android:id="@+id/tv_class_name"
            style="@style/ClassConnect.Text.Title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/icon_container"
            app:layout_constraintTop_toTopOf="@+id/icon_container"
            tools:text="Mathematics 101" />

        <TextView
            android:id="@+id/tv_subject"
            style="@style/ClassConnect.Text.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/icon_container"
            app:layout_constraintTop_toBottomOf="@+id/tv_class_name"
            tools:text="Algebra &amp; Geometry" />

        <!-- Info row -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@+id/icon_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/icon_container"
            app:layout_constraintTop_toBottomOf="@+id/tv_subject">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_person"
                app:tint="@color/text_hint" />

            <TextView
                android:id="@+id/tv_teacher"
                style="@style/ClassConnect.Text.Caption"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_secondary"
                tools:text="Mr. Smith" />

            <!-- Pill for student count -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_16"
                android:backgroundTint="@color/premium_surface_tint"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_people"
                    app:tint="@color/brand_primary" />

                <TextView
                    android:id="@+id/tv_student_count"
                    style="@style/ClassConnect.Text.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/brand_primary"
                    android:textStyle="bold"
                    tools:text="32" />
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
