<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_premium">

    <!-- Offline banner -->
    <TextView
        android:id="@+id/banner_offline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/semantic_warning"
        android:gravity="center"
        android:padding="6dp"
        android:text="@string/offline_banner"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Campus WiFi indicator -->
    <TextView
        android:id="@+id/tv_campus_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:background="@drawable/bg_tag_success"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="@string/on_campus"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        android:visibility="gone" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="@dimen/space_1">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:orientation="vertical"
                android:paddingBottom="100dp">

                <!-- HEADER -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/screen_padding_h"
                    android:paddingTop="@dimen/space_5"
                    android:paddingBottom="@dimen/space_3">

                    <LinearLayout
                        android:id="@+id/header_text_group"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/header_actions"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tv_greeting"
                            style="@style/ClassConnect.Text.Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/good_morning" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tv_name"
                            style="@style/ClassConnect.Text.Headline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/app_name"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/header_actions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp">

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:id="@+id/iv_avatar"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:contentDescription="@string/user_avatar"
                                android:src="@drawable/ic_profile"
                                app:civ_border_color="@color/brand_primary"
                                app:civ_border_width="2dp" />

                            <View
                                android:id="@+id/view_avatar_dot"
                                android:layout_width="11dp"
                                android:layout_height="11dp"
                                android:layout_gravity="top|end"
                                android:background="@drawable/bg_notification_dot"
                                android:visibility="gone" />
                        </FrameLayout>

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:id="@+id/iv_notification_bell"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_chip"
                                android:contentDescription="@string/notifications"
                                android:padding="8dp"
                                android:src="@drawable/ic_notifications"
                                app:tint="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/tv_notification_badge"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="top|end"
                                android:background="@drawable/bg_notification_dot"
                                android:gravity="center"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:visibility="gone" />
                        </FrameLayout>
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- ── QUICK ACTIONS ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/space_4"
                    android:paddingBottom="@dimen/space_4">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_mark_attendance"
                        style="@style/ClassConnect.Button.Tonal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_1"
                        android:layout_weight="1"
                        android:text="@string/scan_qr"
                        android:textSize="11sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_join_class"
                        style="@style/ClassConnect.Button.Tonal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/space_1"
                        android:layout_weight="1"
                        android:text="@string/join_class"
                        android:textSize="11sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_ai_buddy"
                        style="@style/ClassConnect.Button.Tonal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_1"
                        android:layout_weight="1"
                        android:text="@string/ai_buddy"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- ── TODAY'S CLASSES ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/screen_padding_h"
                    android:paddingBottom="@dimen/space_2">

                    <com.google.android.material.textview.MaterialTextView
                        style="@style/ClassConnect.Text.SectionTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/today_classes"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_view_timetable"
                        style="@style/ClassConnect.Text.Link"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/space_1"
                        android:text="@string/view_full_timetable"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_no_today_classes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="8dp"
                    android:text="@string/no_classes_today"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_today_classes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_4"
                    android:clipToPadding="false"
                    android:layoutAnimation="@anim/layout_animation_slide_horizontal"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/space_3" />

                <!-- ── UPCOMING DEADLINES ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/screen_padding_h"
                    android:paddingBottom="@dimen/space_2">

                    <com.google.android.material.textview.MaterialTextView
                        style="@style/ClassConnect.Text.SectionTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/upcoming_deadlines"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_deadlines_empty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_upcoming_deadlines"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_deadlines"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_4"
                    android:layoutAnimation="@anim/layout_animation_stagger"
                    android:nestedScrollingEnabled="false" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/screen_padding_h"
                    android:paddingBottom="@dimen/space_2">

                    <com.google.android.material.textview.MaterialTextView
                        style="@style/ClassConnect.Text.SectionTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/recent_announcements"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_announcements_empty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_recent_announcements"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_announcements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layoutAnimation="@anim/layout_animation_stagger"
                    android:nestedScrollingEnabled="false"
                    android:paddingBottom="@dimen/space_4" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
