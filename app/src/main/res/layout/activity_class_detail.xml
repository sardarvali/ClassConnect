    <!-- ═══ COLLAPSING APP BAR ═══ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:liftOnScroll="true"
        app:liftOnScrollColor="@color/bg_base">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            app:contentScrim="@color/bg_base"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
            app:scrimAnimationDuration="300"
            app:titleEnabled="false">

            <!-- Gradient background -->
            <View
                android:id="@+id/headerGradient"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_class_header_gradient"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.4" />

            <!-- Decorative floating circles -->
            <View
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-80dp"
                android:layout_marginEnd="-80dp"
                android:background="@drawable/bg_circle_overlay"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.6" />

            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="-30dp"
                android:layout_marginBottom="-30dp"
                android:background="@drawable/bg_circle_overlay"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.3" />

            <!-- TOP ROW -->
            <LinearLayout
                android:id="@+id/topActionBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp"
                app:layout_collapseMode="pin">

                <!-- Back -->
                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_icon_glass"
                    android:contentDescription="@string/class_detail_back"
                    android:padding="9dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/text_primary" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- Class code pill -->
                <LinearLayout
                    android:id="@+id/classCodePill"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_glass_pill"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="10dp">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_copy"
                        app:tint="@color/text_primary" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvClassCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:letterSpacing="0.12"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Settings / more -->
                <ImageView
                    android:id="@+id/btnSettings"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_icon_glass"
                    android:contentDescription="@string/class_detail_settings"
                    android:padding="9dp"
                    android:src="@drawable/ic_more_vert"
                    app:tint="@color/text_primary" />
            </LinearLayout>

            <!-- BOTTOM ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingBottom="16dp"
                app:layout_collapseMode="parallax">

                <!-- Subject label -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvSubject"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.15"
                    android:textAllCaps="true"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textStyle="bold" />

                <!-- Class name -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvClassName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="?attr/textAppearanceHeadlineLarge"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold" />

                <!-- Info pills row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Teacher pill -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_glass_pill"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_person"
                            app:tint="@color/text_primary" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvTeacherName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:ellipsize="end"
                            android:fontFamily="sans-serif-medium"
                            android:maxWidth="120dp"
                            android:maxLines="1"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <!-- Members pill -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_glass_pill"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_people"
                            app:tint="@color/text_primary" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvMemberCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:fontFamily="sans-serif-medium"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <!-- Chat button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChat"
                        style="@style/ClassConnect.Button.Tonal"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="12dp"
                        android:text="@string/tab_chat"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/semantic_info_surface"
                        app:cornerRadius="100dp"
                        app:icon="@drawable/ic_chat"
                        app:iconPadding="4dp"
                        app:iconSize="14dp" />
                </LinearLayout>
            </LinearLayout>

        </com.google.android.material.appbar.CollapsingToolbarLayout>

        <!-- ═══ TAB LAYOUT ═══ -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/bg_base"
            android:paddingHorizontal="8dp"
            app:tabGravity="start"
            app:tabIndicator="@drawable/bg_tab_indicator_pill"
            app:tabIndicatorColor="@color/brand_primary"
            app:tabIndicatorGravity="center"
            app:tabIndicatorHeight="36dp"
            app:tabMode="scrollable"
            app:tabPaddingEnd="4dp"
            app:tabPaddingStart="4dp"
            app:tabRippleColor="@android:color/transparent"
            app:tabSelectedTextColor="@color/text_on_brand"
            app:tabTextAppearance="@style/ClassConnect.Tab"
            app:tabTextColor="@color/text_secondary" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ═══ CONTENT ═══ -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
