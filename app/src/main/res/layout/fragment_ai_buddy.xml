<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:layoutAnimation="@anim/layout_animation_from_bottom"
        android:paddingHorizontal="@dimen/space_2"
        android:paddingTop="@dimen/space_3"
        android:paddingBottom="@dimen/space_2"
        app:layout_constraintBottom_toTopOf="@id/layout_suggestions"
        app:layout_constraintTop_toTopOf="parent" />

    <HorizontalScrollView
        android:id="@+id/layout_suggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/space_3"
        android:paddingBottom="@dimen/space_1"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/input_card">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/space_2">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip1"
                style="@style/ClassConnect.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_2"
                android:text="@string/ai_chip_explain" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip2"
                style="@style/ClassConnect.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_2"
                android:text="@string/ai_chip_practice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip3"
                style="@style/ClassConnect.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_2"
                android:text="@string/ai_chip_summarize" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip4"
                style="@style/ClassConnect.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_chip_tips" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Input bar wrapped in card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/input_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_3"
        android:layout_marginBottom="@dimen/space_2"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardCornerRadius="@dimen/radius_xlarge"
        app:cardElevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:strokeColor="@color/border_default"
        app:strokeWidth="1dp">

        <LinearLayout
            android:id="@+id/input_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_3"
            android:paddingVertical="@dimen/space_1">

            <ImageButton
                android:id="@+id/btn_clear"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/delete"
                android:padding="6dp"
                android:src="@drawable/ic_delete"
                app:tint="@color/text_hint" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:gravity="top|start"
                android:hint="@string/ask_anything"
                android:maxLines="3"
                android:minHeight="48dp"
                android:paddingHorizontal="@dimen/space_2"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/btn_voice"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/ai_voice_input"
                android:padding="6dp"
                android:src="@drawable/ic_mic"
                app:tint="@color/brand_primary" />

            <ImageButton
                android:id="@+id/btn_send"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_brand_button"
                android:contentDescription="@string/submit"
                android:padding="10dp"
                android:src="@drawable/ic_send"
                app:tint="@color/white" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/input_card"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- FAB: share/use last AI response -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_use_response"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/space_3"
        android:layout_marginBottom="@dimen/space_2"
        android:text="@string/ai_use_response"
        android:textSize="12sp"
        android:visibility="gone"
        app:icon="@drawable/ic_ai"
        app:layout_constraintBottom_toTopOf="@id/layout_suggestions"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
