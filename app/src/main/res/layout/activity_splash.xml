<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/splash_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_background">

    <com.syed.classconnect.ui.splash.NeuralBackgroundView
        android:id="@+id/neural_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.syed.classconnect.ui.splash.ParticleBurstView
        android:id="@+id/particle_burst"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="20dp">

        <TextView
            android:id="@+id/logo_view"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:text="CC"
            android:textColor="@android:color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="14dp" />

        <TextView
            android:id="@+id/tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:layout_gravity="center_horizontal"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.5"
            android:text="CLASSCONNECT"
            android:textAllCaps="true"
            android:textColor="@color/splash_light_purple"
            android:textSize="11sp"
            android:layout_marginTop="0dp" />

        <FrameLayout
            android:id="@+id/loader_container"
            android:layout_width="80dp"
            android:layout_height="2dp"
            android:layout_marginTop="18dp"
            android:layout_gravity="center_horizontal">

            <View
                android:id="@+id/loader_track"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <View
                android:id="@+id/loader_fill"
                android:layout_width="0dp"
                android:layout_height="match_parent" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/role_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal">

            <TextView
                android:id="@+id/chip_admin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:alpha="0"
                android:letterSpacing="0.08"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="ADMIN"
                android:textSize="9sp"
                android:textStyle="bold"
                android:translationY="8dp" />

            <TextView
                android:id="@+id/chip_teacher"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:alpha="0"
                android:letterSpacing="0.08"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="TEACHER"
                android:textSize="9sp"
                android:textStyle="bold"
                android:translationY="8dp" />

            <TextView
                android:id="@+id/chip_student"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0"
                android:letterSpacing="0.08"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="STUDENT"
                android:textSize="9sp"
                android:textStyle="bold"
                android:translationY="8dp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
