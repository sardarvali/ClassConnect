<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_4">

        <!-- TEACHER SECTION -->
        <LinearLayout
            android:id="@+id/teacherPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.textview.MaterialTextView
                style="@style/ClassConnect.Text.SectionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_2"
                android:text="@string/attendance_teacher_controls" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_session"
                style="@style/ClassConnect.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/start_attendance"
                android:textStyle="bold"
                app:icon="@drawable/ic_qr_code"
                app:iconGravity="textStart" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/activeSessionCard"
                style="@style/ClassConnect.Surface.Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_4"
                android:visibility="gone"
                app:cardBackgroundColor="@color/semantic_success_surface"
                app:cardCornerRadius="@dimen/radius_medium"
                app:strokeColor="@color/semantic_success"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_4">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_4"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_marginEnd="@dimen/space_2"
                            android:background="@drawable/bg_dot_success" />

                        <com.google.android.material.textview.MaterialTextView
                            style="@style/ClassConnect.Text.Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/attendance_session_active"
                            android:textColor="?attr/colorPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/iv_qr_code"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:contentDescription="@string/scan_qr"
                        android:scaleType="centerCrop" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_timer"
                        style="@style/ClassConnect.Text.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_3"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/attendance_session_timer_placeholder"
                        android:textColor="?attr/colorPrimary" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_present_count"
                        style="@style/ClassConnect.Text.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_2"
                        android:text="@string/attendance_present_count_placeholder"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_end_session"
                        style="@style/ClassConnect.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4"
                        android:text="@string/end_session"
                        android:textColor="@color/semantic_error"
                        app:strokeColor="@color/semantic_error" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- STUDENT SECTION -->
        <LinearLayout
            android:id="@+id/studentPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.textview.MaterialTextView
                style="@style/ClassConnect.Text.SectionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_2"
                android:text="@string/attendance_student_section" />

            <com.google.android.material.card.MaterialCardView
                style="@style/ClassConnect.Surface.Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_4"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="@dimen/radius_medium"
                app:strokeColor="@color/border_subtle"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_5">

                    <com.google.android.material.textview.MaterialTextView
                        style="@style/ClassConnect.Text.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/my_attendance"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tv_attendance_rate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/attendance_rate_placeholder"
                            android:textAppearance="?attr/textAppearanceHeadlineSmall"
                            android:textColor="?attr/colorPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_scan_qr"
                style="@style/ClassConnect.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/scan_qr"
                android:textStyle="bold"
                app:icon="@drawable/ic_qr_scan"
                app:iconGravity="textStart" />
        </LinearLayout>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_history_title"
            style="@style/ClassConnect.Text.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:layout_marginBottom="@dimen/space_3"
            android:text="@string/attendance_history_title" />

        <!-- HISTORY SECTION -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/historyRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/emptyHistoryState"
            style="@style/ClassConnect.Text.Title"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:drawablePadding="@dimen/space_3"
            android:gravity="center"
            android:text="@string/no_attendance_history"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:visibility="gone"
            app:drawableTopCompat="@drawable/ic_history"
            app:drawableTint="?attr/colorOnSurfaceVariant" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
