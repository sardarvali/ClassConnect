<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_submissions_title"
        style="@style/ClassConnect.Text.SectionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/submissions" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <com.google.android.material.chip.ChipGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_all"
                style="@style/ClassConnect.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/class_filter_all" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_submitted"
                style="@style/ClassConnect.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/submitted" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_graded"
                style="@style/ClassConnect.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/graded" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_not_submitted"
                style="@style/ClassConnect.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/not_submitted" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/layout_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:alpha="0.4"
            android:src="@drawable/ic_assignment" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/no_submissions_yet"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_submissions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

</LinearLayout>

