<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding_h"
        android:paddingTop="@dimen/space_5"
        android:paddingBottom="@dimen/space_12">

        <!-- Section label -->
        <TextView
            style="@style/ClassConnect.Text.SectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_3"
            android:text="@string/admin_overview" />

        <!-- Stats row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                style="@style/ClassConnect.Surface.Section"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_2"
                android:layout_weight="1"
                app:cardCornerRadius="@dimen/radius_xlarge">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_4">

                    <TextView
                        android:id="@+id/tv_total_users"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@integer/zero"
                        android:textColor="@color/brand_primary"
                        android:textSize="@dimen/text_2xl"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:text="@string/total_users"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_xs" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/ClassConnect.Surface.Section"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_2"
                android:layout_weight="1"
                app:cardCornerRadius="@dimen/radius_xlarge">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_4">

                    <TextView
                        android:id="@+id/tv_teachers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@integer/zero"
                        android:textColor="@color/semantic_success"
                        android:textSize="@dimen/text_2xl"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:text="@string/admin_teachers"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_xs" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Stats row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                style="@style/ClassConnect.Surface.Section"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_2"
                android:layout_weight="1"
                app:cardCornerRadius="@dimen/radius_xlarge">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_4">

                    <TextView
                        android:id="@+id/tv_students"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@integer/zero"
                        android:textColor="@color/brand_accent"
                        android:textSize="@dimen/text_2xl"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:text="@string/admin_students"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_xs" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/ClassConnect.Surface.Section"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_2"
                android:layout_weight="1"
                app:cardCornerRadius="@dimen/radius_xlarge">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_4">

                    <TextView
                        android:id="@+id/tv_classes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@integer/zero"
                        android:textColor="@color/semantic_warning"
                        android:textSize="@dimen/text_2xl"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:text="@string/admin_classes"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_xs" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Pending approvals -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_pending_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_3"
            android:background="@drawable/bg_rounded_16"
            android:backgroundTint="@color/semantic_warning_surface"
            android:drawableStart="@drawable/ic_people"
            android:drawablePadding="@dimen/space_2"
            android:gravity="center_vertical"
            android:padding="@dimen/space_4"
            android:text="@string/pending_approvals_summary"
            android:textColor="@color/semantic_warning"
            android:textSize="@dimen/text_base"
            android:textStyle="bold"
            app:drawableTint="@color/semantic_warning" />

        <!-- Role Change History button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_role_change_history"
            style="@style/ClassConnect.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:text="@string/role_change_history" />

    </LinearLayout>
</ScrollView>
