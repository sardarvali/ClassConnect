    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTeacherOrAdmin() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return request.auth != null && (role == 'teacher' || role == 'admin');
    }

    function isMemberOrTeacher(classId) {
      let cls = get(/databases/$(database)/documents/classes/$(classId)).data;
      return request.auth != null && (
        request.auth.uid in cls.studentIds ||
        cls.teacherId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
